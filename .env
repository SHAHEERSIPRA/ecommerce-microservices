# ══════════════════════════════════════════════════════
#  ECS Microservices — Environment Variables
#  Copy this file to .env in the project root or
#  set these in your ECS Task Definitions / docker-compose
# ══════════════════════════════════════════════════════

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017

# ─── User Service ─────────────────────────────────────
USER_SERVICE_PORT=4001
USER_SERVICE_MONGO_URI=mongodb://mongo:27017/userdb
USER_SERVICE_ORDER_SERVICE_URL=http://order-service:4003

# ─── Product Service ─────────────────────────────────
PRODUCT_SERVICE_PORT=4002
PRODUCT_SERVICE_MONGO_URI=mongodb://mongo:27017/productdb
PRODUCT_SERVICE_ORDER_SERVICE_URL=http://order-service:4003

# ─── Order Service ────────────────────────────────────
ORDER_SERVICE_PORT=4003
ORDER_SERVICE_MONGO_URI=mongodb://mongo:27017/orderdb
ORDER_SERVICE_USER_SERVICE_URL=http://user-service:4001
ORDER_SERVICE_PRODUCT_SERVICE_URL=http://product-service:4002

# ─── Frontend (Next.js) ──────────────────────────────
# Production (Azure VM)
NEXT_PUBLIC_USER_SERVICE_URL=http://4.186.31.149:4001
NEXT_PUBLIC_PRODUCT_SERVICE_URL=http://4.186.31.149:4002
NEXT_PUBLIC_ORDER_SERVICE_URL=http://4.186.31.149:4003

# ─── ECS / AWS (used during deployment) ──────────────
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
# ECS_CLUSTER_NAME=ecs-learning-cluster
# VPC_ID=vpc-xxxxxxxxx
# SUBNET_1=subnet-xxxxxxxx
# SUBNET_2=subnet-xxxxxxxx
# SECURITY_GROUP=sg-xxxxxxxx
# ALB_DNS=ecs-learning-alb-xxxxxxxxx.us-east-1.elb.amazonaws.com
